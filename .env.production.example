# Web (Vercel)
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# API (Render/Fly/Oracle)
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://<vercel-web-subdomain>.vercel.app
DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require
REDIS_URL=rediss://default:<password>@<upstash-host>:<port>
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
OTP_PROVIDER=stub
API_DOMAIN=api.example.com

# OAuth (kept for upcoming real Google OAuth wiring)
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=https://api.example.com/api/auth/google/callback
